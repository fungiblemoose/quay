<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the QuayBar .app bundle assembled by scripts/install-bar.sh.
  LSUIElement makes it a menu-bar-only (accessory) app: no Dock icon, just the
  status item — same shape as OrbStack's menu bar app.
-->
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>QuayBar</string>
    <key>CFBundleIdentifier</key>
    <string>com.backspinlabs.quay.bar</string>
    <key>CFBundleName</key>
    <string>QuayBar</string>
    <key>CFBundleDisplayName</key>
    <string>QuayBar</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
